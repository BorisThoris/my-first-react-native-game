{
  "name": "my-react-native-game",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "start:lan": "expo start --lan",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "build:web": "npx expo export",
    "electron-build": "electron-builder",
    "electron-dev": "electron  main.js",
    "clean": "rm -rf .expo node_modules/.cache && yarn install",
    "clean:win": "if exist .expo rmdir /s /q .expo && if exist node_modules\\.cache rmdir /s /q node_modules\\.cache && yarn install",
    "doctor": "npx expo-doctor",
    "prestart": "node -e \"console.log('Node version:', process.version); if (parseInt(process.version.slice(1).split('.')[0]) > 20) console.warn('⚠️  Warning: Node.js v' + process.version + ' may cause Expo issues. Consider using Node.js v18 or v20.');\""
  },
  "build": {
    "appId": "com.yourapp.id",
    "win": {
      "target": "nsis"
    },
    "extraMetadata": {
      "main": "./main.js"
    }
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/metro-config": "54.0.4",
    "@expo/vector-icons": "15.0.2",
    "@react-native-community/cli-server-api": "20.0.2",
    "@react-navigation/native": "6.1.18",
    "electron": "38.1.2",
    "expo": "51.0.39",
    "expo-constants": "16.0.2",
    "expo-font": "14.0.8",
    "expo-linking": "6.3.1",
    "expo-notifications": "0.28.19",
    "expo-router": "3.5.24",
    "expo-splash-screen": "0.27.7",
    "expo-status-bar": "1.12.1",
    "expo-system-ui": "3.0.7",
    "expo-web-browser": "13.0.3",
    "metro": "0.80.12",
    "metro-cache": "0.80.12",
    "metro-resolver": "0.80.12",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-safe-area-context": "5.6.1",
    "react-native-screens": "4.16.0",
    "react-native-web": "0.21.1"
  },
  "devDependencies": {
    "@babel/core": "7.28.4",
    "@babel/eslint-parser": "7.28.4",
    "@types/jest": "30.0.0",
    "@types/react": "19.1.13",
    "@types/react-test-renderer": "19.1.0",
    "babel-eslint": "10.1.0",
    "electron-builder": "26.0.12",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.0.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-native": "5.0.0",
    "eslint-plugin-react-perf": "3.3.3",
    "eslint-plugin-sort": "4.0.0",
    "jest": "30.1.3",
    "jest-expo": "51.0.4",
    "prettier": "3.6.2",
    "prettier-eslint": "16.4.2",
    "react-test-renderer": "18.3.1",
    "typescript": "5.9.2"
  },
  "private": true
}