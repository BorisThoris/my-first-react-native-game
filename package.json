{
    "name": "memory-dungeon-steam",
    "version": "1.0.0",
    "private": true,
    "author": "Memory Dungeon",
    "license": "UNLICENSED",
    "description": "Windows-first Steam desktop arcade rebuild of Memory Dungeon.",
    "main": "dist-electron/main/index.js",
    "scripts": {
        "dev": "concurrently -k \"yarn dev:renderer\" \"yarn dev:electron:watch\" \"yarn dev:electron\"",
        "dev:renderer": "vite",
        "dev:electron:watch": "tsup --config tsup.config.ts --watch",
        "dev:electron": "wait-on tcp:5173 file:dist-electron/main/index.js file:dist-electron/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon dist-electron/main/index.js",
        "build": "yarn clean && yarn build:renderer && yarn build:electron",
        "build:renderer": "vite build",
        "build:electron": "tsup --config tsup.config.ts",
        "clean": "rimraf dist dist-electron release",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "package:dir": "yarn build && electron-builder --dir",
        "package:win": "yarn build && electron-builder --win nsis",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "@react-three/fiber": "^9.5.0",
        "electron-store": "11.0.2",
        "pixi.js": "8.17.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "steamworks.js": "0.4.0",
        "three": "^0.183.2",
        "zustand": "5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "9.38.0",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.5.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "4.7.0",
        "concurrently": "9.2.1",
        "cross-env": "10.1.0",
        "electron": "41.1.0",
        "electron-builder": "26.8.1",
        "electronmon": "2.0.4",
        "eslint": "9.38.0",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "globals": "17.4.0",
        "happy-dom": "17.6.3",
        "rimraf": "6.1.3",
        "tsup": "8.5.1",
        "typescript": "6.0.2",
        "typescript-eslint": "8.57.2",
        "vite": "6.4.1",
        "vitest": "4.1.2",
        "wait-on": "9.0.4"
    },
    "build": {
        "appId": "com.memorydungeon.steam",
        "productName": "Memory Dungeon",
        "asar": true,
        "asarUnpack": [
            "node_modules/steamworks.js/dist/win64/**/*"
        ],
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "package.json"
        ],
        "extraFiles": [
            {
                "from": "steam_appid.txt",
                "to": "."
            },
            {
                "from": "node_modules/steamworks.js/dist/win64",
                "to": ".",
                "filter": [
                    "steam_api64.dll"
                ]
            }
        ],
        "directories": {
            "buildResources": "build",
            "output": "release"
        },
        "win": {
            "icon": "icon.png",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": false
        }
    }
}
