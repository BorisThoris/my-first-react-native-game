{
    "name": "memory-dungeon-steam",
    "version": "1.0.0",
    "private": true,
    "author": "Memory Dungeon",
    "packageManager": "yarn@1.22.22",
    "engines": {
        "node": ">=22.9.0"
    },
    "license": "UNLICENSED",
    "description": "Windows-first Steam desktop arcade rebuild of Memory Dungeon.",
    "main": "dist-electron/main/index.js",
    "scripts": {
        "dev": "concurrently -k \"yarn dev:renderer\" \"yarn dev:electron:watch\" \"yarn dev:electron\"",
        "dev:renderer": "vite",
        "dev:electron:watch": "tsup --config tsup.config.ts --watch",
        "dev:electron": "wait-on tcp:5173 file:dist-electron/main/index.js file:dist-electron/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon dist-electron/main/index.js",
        "build": "yarn clean && yarn build:renderer && yarn build:electron",
        "build:cloudflare": "yarn build:renderer",
        "build:renderer": "vite build",
        "build:electron": "tsup --config tsup.config.ts",
        "clean": "rimraf dist dist-electron release",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:visual": "yarn test:e2e:visual:device-grid",
        "test:e2e:visual:device-grid": "playwright test e2e/visual-inventory-capture.spec.ts --workers=1",
        "test:e2e:visual:device-grid:shard1": "playwright test e2e/visual-inventory-capture.spec.ts --shard=1/4",
        "test:e2e:visual:device-grid:shard2": "playwright test e2e/visual-inventory-capture.spec.ts --shard=2/4",
        "test:e2e:visual:device-grid:shard3": "playwright test e2e/visual-inventory-capture.spec.ts --shard=3/4",
        "test:e2e:visual:device-grid:shard4": "playwright test e2e/visual-inventory-capture.spec.ts --shard=4/4",
        "test:e2e:visual:smoke": "playwright test e2e/visual-screens.mobile.spec.ts e2e/visual-screens.standard.spec.ts --workers=1",
        "test:e2e:visual:smoke:shard1": "playwright test e2e/visual-screens.mobile.spec.ts e2e/visual-screens.standard.spec.ts --shard=1/3",
        "test:e2e:visual:smoke:shard2": "playwright test e2e/visual-screens.mobile.spec.ts e2e/visual-screens.standard.spec.ts --shard=2/3",
        "test:e2e:visual:smoke:shard3": "playwright test e2e/visual-screens.mobile.spec.ts e2e/visual-screens.standard.spec.ts --shard=3/3",
        "test:e2e:renderer-qa": "playwright test e2e/mobile-layout.spec.ts e2e/navigation-flow.spec.ts e2e/scholar-contract.spec.ts e2e/wild-run.spec.ts e2e/tile-card-face-dom.spec.ts e2e/tile-card-face-webgl.spec.ts e2e/tile-board-raycast.spec.ts --workers=1",
        "capture:ui-audit": "cross-env VISUAL_CAPTURE_ROOT=docs/visual-capture yarn test:e2e:visual:device-grid",
        "capture:visual-inventory": "yarn capture:ui-audit",
        "capture:ui-design-reference": "playwright test e2e/ui-design-reference.spec.ts --workers=1",
        "capture:endproduct-parity": "cross-env VISUAL_CAPTURE_ROOT=docs/visual-capture/endproduct-parity playwright test e2e/visual-endproduct-parity.spec.ts --workers=1",
        "capture:matched-flame": "playwright test e2e/capture-matched-flame.spec.ts --workers=1",
        "docs:ui-audit": "node scripts/generate-visual-inventory-md.mjs",
        "docs:visual-inventory": "yarn docs:ui-audit",
        "docs:mechanics-appendix": "tsx scripts/run-mechanics-appendix.ts",
        "assets:choose-path-bg": "node scripts/generate-choose-path-background.mjs",
        "wip:extract-endproduct": "node scripts/extract-endproduct-wip-assets.mjs",
        "wip:extract-endproduct:react": "node scripts/extract-endproduct-wip-assets.mjs --emit-react",
        "wip:extract-endproduct:png-only": "node scripts/extract-endproduct-wip-assets.mjs --no-svg",
        "imagegen": "node scripts/card-pipeline/image_gen.mjs",
        "card-texture:ideal": "node scripts/card-pipeline/print-card-texture-ideal.mjs",
        "card-texture:ai-brief": "node scripts/card-pipeline/print-card-texture-ideal.mjs --ai-brief",
        "capture:ui-vs-assets": "node scripts/card-pipeline/capture-ui-vs-asset-screens.mjs",
        "png:trim-bbox": "node scripts/card-pipeline/trim-png-bounding-box.mjs",
        "test:e2e:ui": "playwright test --ui",
        "package:dir": "yarn build && electron-builder --dir",
        "package:win": "yarn build && electron-builder --win nsis",
        "postinstall": "node scripts/postinstall.cjs"
    },
    "dependencies": {
        "@cross-repo-libs/notifications": "file:./packages/notifications",
        "@fontsource/cinzel": "5.2.5",
        "@fontsource/source-sans-3": "5.2.5",
        "@react-three/fiber": "^9.5.0",
        "@react-three/postprocessing": "^3.0.4",
        "electron-store": "11.0.2",
        "pixi.js": "8.17.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "steamworks.js": "0.4.0",
        "three": "^0.183.2",
        "zustand": "5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "9.38.0",
        "@fit-screen/react": "^1.0.2",
        "@playwright/test": "1.57.0",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.5.0",
        "@types/pixelmatch": "^5.2.6",
        "@types/pngjs": "^6.0.5",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "4.7.0",
        "concurrently": "9.2.1",
        "cross-env": "10.1.0",
        "electron": "41.1.0",
        "electron-builder": "26.8.1",
        "electronmon": "2.0.4",
        "eslint": "9.38.0",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "globals": "17.4.0",
        "happy-dom": "17.6.3",
        "imagetracerjs": "^1.2.6",
        "pixelmatch": "5.3.0",
        "pngjs": "^7.0.0",
        "rimraf": "6.1.3",
        "tsup": "8.5.1",
        "tsx": "^4.21.0",
        "typescript": "6.0.2",
        "typescript-eslint": "8.57.2",
        "vite": "6.4.1",
        "vitest": "4.1.2",
        "wait-on": "9.0.4"
    },
    "resolutions": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "zustand": "5.0.12"
    },
    "build": {
        "appId": "com.memorydungeon.steam",
        "productName": "Memory Dungeon",
        "asar": true,
        "asarUnpack": [
            "node_modules/steamworks.js/dist/win64/**/*"
        ],
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "package.json"
        ],
        "extraFiles": [
            {
                "from": "steam_appid.txt",
                "to": "."
            },
            {
                "from": "node_modules/steamworks.js/dist/win64",
                "to": ".",
                "filter": [
                    "steam_api64.dll"
                ]
            }
        ],
        "directories": {
            "buildResources": "build",
            "output": "release"
        },
        "win": {
            "icon": "icon.png",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": false
        }
    }
}
