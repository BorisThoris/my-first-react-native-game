# Copy to scripts/audio-pipeline/environment.audio.local.env (gitignored) and fill values.
# PowerShell before a batch run:
#   Get-Content .\scripts\audio-pipeline\environment.audio.local.env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { Set-Item -Path "Env:$($matches[1])" -Value $matches[2].Trim() } }

# Hugging Face — required if checkpoints are gated for your account
HF_TOKEN=

# Prefer GPU when running batch_ace_step.py (matches --device)
ACESTEP_DEVICE=cuda

# Weights folder (HuggingFace-style repo next to the game), e.g. sibling clone:
#   C:\Users\you\Desktop\Repos\Ace-Step1.5
# Must contain `acestep-v15-turbo/` and `acestep-5Hz-lm-1.7B/` (and embeddings/VAE as in that repo).
# ACESTEP_PROJECT_ROOT=

# If LM/embeddings live elsewhere, override (defaults: <ACESTEP_PROJECT_ROOT>/checkpoints if that dir exists, else project root)
# ACESTEP_CHECKPOINTS_DIR=

# Optional overrides (see scripts/audio-pipeline/batch_ace_step.py --help)
# ACESTEP_CONFIG_PATH=
# ACESTEP_LM_MODEL_PATH=
# ACESTEP_LM_BACKEND=
# ACESTEP_COMPILE_MODEL=0
