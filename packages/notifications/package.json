{
  "name": "@cross-repo-libs/notifications",
  "version": "0.1.0",
  "description": "Toast + confirm notifications (Zustand store, imperative bridge, accessible DOM host) extracted from MusicalAppReactConcept patterns",
  "type": "module",
  "sideEffects": [
    "./dist/notification-host.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/notification-host.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-css.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
